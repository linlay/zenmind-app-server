# 必填：宿主机 Backend 端口映射。
# Required: host port mapping for the backend service.
BACKEND_PORT=11952

# 必填：宿主机 Frontend 端口映射。
# Required: host port mapping for the frontend service.
FRONTEND_PORT=11950

# 可选：覆盖认证服务对外 issuer。
# Optional: override the public issuer used by the auth service.
# AUTH_ISSUER=http://localhost:11952

# 可选：覆盖数据库文件路径；容器内默认仍为 /data/auth.db。
# Optional: override the database file path; the container default remains /data/auth.db.
# AUTH_DB_PATH=/data/auth.db

# 可选：覆盖管理员用户名，默认值在源代码内置为 admin。
# Optional: override the admin username; the built-in code default is admin.
# AUTH_ADMIN_USERNAME=admin

# 可选：覆盖应用用户名，默认值在源代码内置为 app。
# Optional: override the app username; the built-in code default is app.
# AUTH_APP_USERNAME=app

# 可选：覆盖 App access token 默认 TTL。
# Optional: override the default App access token TTL.
# AUTH_APP_ACCESS_TTL=PT10M

# 可选：覆盖 App 最大 access token TTL。
# Optional: override the maximum App access token TTL.
# AUTH_APP_MAX_ACCESS_TTL=P30D

# 可选：覆盖是否轮换设备令牌。
# Optional: override whether device tokens rotate.
# AUTH_APP_ROTATE_DEVICE_TOKEN=true

# 可选：覆盖 OAuth2 access token TTL。
# Optional: override the OAuth2 access token TTL.
# AUTH_TOKEN_ACCESS_TTL=PT15M

# 可选：覆盖 OAuth2 refresh token TTL。
# Optional: override the OAuth2 refresh token TTL.
# AUTH_TOKEN_REFRESH_TTL=P30D

# 可选：覆盖是否轮换 refresh token。
# Optional: override whether refresh tokens rotate.
# AUTH_TOKEN_ROTATE_REFRESH_TOKEN=true

# 可选：覆盖清理任务保留期。
# Optional: override the cleanup retention duration.
# AUTH_CLEANUP_RETENTION=PT24H

# 可选：覆盖清理任务 cron。
# Optional: override the cleanup cron expression.
# AUTH_CLEANUP_CRON=0 0 * * * *

# 可选：本地直跑 backend 时，临时覆盖可编辑配置文件白名单。
# Optional: temporarily override the editable managed-config allowlist when running backend directly.
# AUTH_EXTERNAL_EDITABLE_FILES=/app/config/zenmind-root.env,/app/config/mcp-server-mock.env

# 可选：本地直跑 backend 时，临时覆盖运行时注册表路径。
# Optional: temporarily override the runtime registry path when running backend directly.
# AUTH_CONFIG_FILES_REGISTRY_PATH=/app/config/config-files.runtime.yml

# 可选：前端构建基础路径。
# Optional: frontend build base path.
VITE_BASE_PATH=/admin/

# 必填：管理员密码 bcrypt；示例仅用于本地开发。
# Required: admin password bcrypt; the sample is for local development only.
AUTH_ADMIN_PASSWORD_BCRYPT='$2a$10$VAC1MOfQV2f6L3LqgU5PweT25AdVaRK3yvMLwXjA0uRUhtnbbQ1ue'

# 必填：应用主密码 bcrypt；示例仅用于本地开发。
# Required: app master password bcrypt; the sample is for local development only.
AUTH_APP_MASTER_PASSWORD_BCRYPT='$2a$10$VAC1MOfQV2f6L3LqgU5PweT25AdVaRK3yvMLwXjA0uRUhtnbbQ1ue'
