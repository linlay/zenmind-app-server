# Port mapping on host machine.
BACKEND_PORT=11952
FRONTEND_PORT=11950

# OAuth/OIDC issuer, should be your real backend URL in production.
AUTH_ISSUER=http://localhost:8080

# Optional path to application.yml (contains external.editable-files allowlist).
# AUTH_APPLICATION_YML_PATH=backend/application.yml

# Optional override for external.editable-files (comma-separated).
# docker compose backend uses the same fixed /app/config mapping by default.
# Keep this value aligned when you run backend outside docker compose.
AUTH_EXTERNAL_EDITABLE_FILES=/app/config/zenmind-root.env,/app/config/mcp-server-mock.env,/app/config/term-webclient-release.env,/app/config/term-webclient-release.application.yml

# Admin login account.
AUTH_ADMIN_USERNAME=admin

# bcrypt for admin password.
# Dev default maps to plain password: password
# 仅用于本地开发；生产环境必须替换为你自己的 bcrypt。
AUTH_ADMIN_PASSWORD_BCRYPT='$2a$10$VAC1MOfQV2f6L3LqgU5PweT25AdVaRK3yvMLwXjA0uRUhtnbbQ1ue'

# Optional App auth settings.
AUTH_APP_ACCESS_TTL=PT10M
# Max custom access TTL (matches Security page limit: 30 days).
AUTH_APP_MAX_ACCESS_TTL=P30D
AUTH_APP_ROTATE_DEVICE_TOKEN=true

# Optional OAuth2 token settings.
AUTH_TOKEN_ACCESS_TTL=PT15M
AUTH_TOKEN_REFRESH_TTL=P30D
AUTH_TOKEN_ROTATE_REFRESH_TOKEN=true

# Optional frontend build setting (used by docker compose build).
VITE_BASE_PATH=/admin/

# App master password bcrypt.
# Dev default maps to plain password: password
# 仅用于本地开发；生产环境必须替换为你自己的 bcrypt。
AUTH_APP_MASTER_PASSWORD_BCRYPT='$2a$10$VAC1MOfQV2f6L3LqgU5PweT25AdVaRK3yvMLwXjA0uRUhtnbbQ1ue'
