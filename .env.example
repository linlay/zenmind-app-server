# Docker-first deployment contract for zenmind-app-server
FRONTEND_PORT=11950

# Public issuer used by OAuth2 / OIDC metadata.
AUTH_ISSUER=https://website.example.com

# Optional identity labels.
AUTH_ADMIN_USERNAME=admin
AUTH_APP_USERNAME=app

# Frontend base path behind the gateway.
VITE_BASE_PATH=/admin/

# Required bcrypt values. Replace before production use and keep single quotes around hashes.
AUTH_ADMIN_PASSWORD_BCRYPT='$2a$10$VAC1MOfQV2f6L3LqgU5PweT25AdVaRK3yvMLwXjA0uRUhtnbbQ1ue'
AUTH_APP_MASTER_PASSWORD_BCRYPT='$2a$10$VAC1MOfQV2f6L3LqgU5PweT25AdVaRK3yvMLwXjA0uRUhtnbbQ1ue'
